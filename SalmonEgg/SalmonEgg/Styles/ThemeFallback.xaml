<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Baseline fallbacks so ThemeResource lookups succeed even before WinUI resources are injected. -->
    <!-- These are kept for non-Windows platforms where XamlControlsResources might not be available. -->
    <Color x:Key="SystemAltHighColor">#FFFFFF</Color>
    <Color x:Key="SystemAccentColor">#005FB8</Color>
    
    <!-- Baseline fallbrushes that the app expects. Linking them to system resources. -->
    <SolidColorBrush x:Key="AccentBrush" Color="{ThemeResource SystemAccentColor}" />
    <SolidColorBrush x:Key="AppBackdropBrush" Color="{ThemeResource SystemAltHighColor}" Opacity="0" /> <!-- Fallback -->
    <SolidColorBrush x:Key="SubtleFillColorTransparentBrush" Color="Transparent" />

    <!-- Polyfill brushes for non-Windows or standard keys used as custom ones -->
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{ThemeResource SystemBaseHighColor}" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{ThemeResource SystemBaseMediumColor}" />
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{ThemeResource SystemControlBackgroundBaseLowBrush}" />
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="{ThemeResource SystemControlBackgroundBaseMediumBrush}" />
    <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="{ThemeResource SystemControlForegroundBaseLowBrush}" />
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="{ThemeResource SystemControlBackgroundAltHighBrush}" />
    
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <StaticResource x:Key="AppBackdropBrush" ResourceKey="LayerOnAcrylicFillColorDefaultBrush" />
            <SolidColorBrush x:Key="AccentBrush" Color="{ThemeResource SystemAccentColor}" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
            <StaticResource x:Key="AppBackdropBrush" ResourceKey="LayerOnAcrylicFillColorDefaultBrush" />
            <SolidColorBrush x:Key="AccentBrush" Color="{ThemeResource SystemAccentColor}" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <StaticResource x:Key="AppBackdropBrush" ResourceKey="LayerOnAcrylicFillColorDefaultBrush" />
            <SolidColorBrush x:Key="AccentBrush" Color="{ThemeResource SystemAccentColor}" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="HighContrast">
            <SolidColorBrush x:Key="AppBackdropBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="AccentBrush" Color="{ThemeResource SystemColorHotlightColor}" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
