<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Reduced motion: override WinUI animation duration resources to zero.
        This is the clean, cross-platform way to suppress template-level animations.
    -->
    <x:String x:Key="ControlNormalAnimationDuration">00:00:00</x:String>
    <x:String x:Key="ControlFastAnimationDuration">00:00:00</x:String>
    <x:String x:Key="ControlFastAnimationAfterDuration">00:00:00</x:String>
    <x:String x:Key="ControlFasterAnimationDuration">00:00:00</x:String>
    <x:String x:Key="ComboBoxItemScaleAnimationDuration">00:00:00</x:String>
    <x:String x:Key="ScrollBarColorChangeDuration">00:00:00</x:String>
    <x:String x:Key="ScrollBarContractDuration">00:00:00</x:String>
    <x:String x:Key="ScrollBarExpandDuration">00:00:00</x:String>
    <x:String x:Key="ScrollBarOpacityChangeDuration">00:00:00</x:String>
    <x:String x:Key="ScrollViewerSeparatorContractDuration">00:00:00</x:String>
    <x:String x:Key="ScrollViewerSeparatorExpandDuration">00:00:00</x:String>
    <x:String x:Key="ScrollViewScrollBarsNoTouchDuration">00:00:00</x:String>
    <x:String x:Key="ScrollViewScrollBarsSeparatorContractDuration">00:00:00</x:String>
    <x:String x:Key="ScrollViewScrollBarsSeparatorExpandDuration">00:00:00</x:String>
    <x:String x:Key="SplitViewPaneAnimationCloseDuration">00:00:00</x:String>
    <x:String x:Key="SplitViewPaneAnimationOpenDuration">00:00:00</x:String>
    <x:String x:Key="SplitViewPaneAnimationOpenPreDuration">00:00:00</x:String>
</ResourceDictionary>
