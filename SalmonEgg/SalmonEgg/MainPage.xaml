<Page
    x:Class="SalmonEgg.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:vm="using:SalmonEgg.Presentation.ViewModels"
    xmlns:nav="using:SalmonEgg.Presentation.ViewModels.Navigation"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="False">

    <Page.Resources>
        <!-- 极简导航项样式 (Nav Rail) -->
        <Style x:Key="NavRailItemStyle" TargetType="ListViewItem">
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid x:Name="LayoutRoot" Background="{TemplateBinding Background}" Height="64">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Target="SelectionIndicator.Visibility" Value="Visible"/>
                                            <Setter Target="ContentPanel.Foreground" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="LayoutRoot.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <!-- 选中状态指示条 -->
                            <Rectangle x:Name="SelectionIndicator"
                                       Width="3" Height="24"
                                       Fill="{ThemeResource AccentBrush}"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>

                            <ContentPresenter x:Name="ContentPanel"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 二级导航项样式 (Sub Menu) -->
        <Style x:Key="SubMenuItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="OuterBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                BorderThickness="1"
                                BorderBrush="Transparent">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="OuterBorder.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Target="OuterBorder.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}"/>
                                            <Setter Target="OuterBorder.BorderBrush" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="SubMenuContentPresenter.Foreground" Value="{ThemeResource AccentBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="SubMenuContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProjectGroupItemStyle" TargetType="ListViewItem" BasedOn="{StaticResource SubMenuItemStyle}">
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="SessionSubMenuItemStyle" TargetType="ListViewItem" BasedOn="{StaticResource SubMenuItemStyle}">
            <!-- Keep the container full-width; indent via Padding instead of Margin -->
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Padding" Value="24,10"/>
        </Style>

        <Style x:Key="SubMenuResizerThumbStyle" TargetType="controls:ResizeGrip">
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="controls:ResizeGrip">
                        <Grid x:Name="Root" Background="Transparent">
                            <Rectangle x:Name="Grip"
                                       Width="1"
                                       HorizontalAlignment="Right"
                                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RightPanelResizerThumbStyle" TargetType="controls:ResizeGrip">
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="controls:ResizeGrip">
                        <Grid x:Name="Root" Background="Transparent">
                            <Rectangle x:Name="Grip"
                                       Width="1"
                                       HorizontalAlignment="Left"
                                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopBarButtonStyle" TargetType="ToggleButton">
            <Setter Property="MinWidth" Value="64"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Native title bar (full customization) -->
        <Border x:Name="AppTitleBar"
                Grid.Row="0"
                Background="Transparent"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Height="48">
            <Grid x:Name="AppTitleBarContent"
                  Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="TitleBarLeftButtons"
                            Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="4"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Visibility="Visible">
                    <Button x:Name="TitleBarBackButton"
                            Style="{StaticResource SubtleButtonStyle}"
                            ToolTipService.ToolTip="返回"
                            Click="OnTitleBarBackClick">
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE72B;"/>
                    </Button>
                    <Button x:Name="TitleBarToggleLeftNavButton"
                            Style="{StaticResource SubtleButtonStyle}"
                            ToolTipService.ToolTip="折叠左侧边栏"
                            Click="OnToggleLeftNavClick">
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE700;"/>
                    </Button>
                </StackPanel>

                <Grid Grid.Column="1"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="TitleBarDragLeft"
                            Grid.Column="0"
                            Background="Transparent"
                            IsHitTestVisible="True"
                            PointerPressed="OnTitleBarDragPointerPressed" />

                    <TextBox x:Name="TopSearchBox"
                             Grid.Column="1"
                             Width="340"
                             Height="32"
                             PlaceholderText="搜索"
                             CornerRadius="8"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />

                    <Border x:Name="TitleBarDragRight"
                            Grid.Column="2"
                            Background="Transparent"
                            IsHitTestVisible="True"
                            PointerPressed="OnTitleBarDragPointerPressed" />
                </Grid>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <ToggleButton x:Name="DiffPanelButton"
                                  Content="Diff"
                                  Tag="Diff"
                                  Style="{StaticResource TopBarButtonStyle}"
                                  Click="OnRightPanelButtonClick" />
                    <ToggleButton x:Name="TodoPanelButton"
                                  Content="Todo"
                                  Tag="Todo"
                                  Style="{StaticResource TopBarButtonStyle}"
                                  Click="OnRightPanelButtonClick" />
                    <ToggleButton x:Name="FilesPanelButton"
                                  Content="Files"
                                  Tag="Files"
                                  Style="{StaticResource TopBarButtonStyle}"
                                  Click="OnRightPanelButtonClick" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 第一列：极简一级导航 (Nav Rail) -->
            <!-- Background 使用 Transparent 配合 App.xaml 中的 Mica 支持，BorderBrush 使用标准分隔线 -->
            <Grid x:Name="MainRailColumn"
                  Grid.Column="0"
                  Width="72"
                  Background="Transparent"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                  BorderThickness="0,0,1,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 主业务导航 (顶部) -->
                <ListView x:Name="MainRailNav" Grid.Row="0"
                          SelectionMode="Single"
                          Padding="0,12,0,0"
                          ItemContainerStyle="{StaticResource NavRailItemStyle}"
                          SelectionChanged="OnMainRailNavSelectionChanged">
                    <ListViewItem x:Name="ChatNavItem">
                        <StackPanel Spacing="4">
                            <FontIcon Glyph="&#xE8BD;" FontSize="20"/>
                            <TextBlock Text="对话" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ListViewItem>
                </ListView>

                <!-- 系统设置导航 (底部) -->
                <ListView x:Name="BottomRailNav" Grid.Row="1"
                          Margin="0,0,0,16"
                          SelectionMode="Single"
                          ItemContainerStyle="{StaticResource NavRailItemStyle}"
                          SelectionChanged="OnBottomRailNavSelectionChanged">
                    <ListViewItem x:Name="SettingsNavItem">
                        <StackPanel Spacing="4">
                            <FontIcon Glyph="&#xE713;" FontSize="20"/>
                            <TextBlock Text="设置" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ListViewItem>
                </ListView>
            </Grid>

            <!-- 第二列：子导航栏（Chat: 项目/会话；Settings: 设置子菜单） -->
            <Grid x:Name="SubMenuColumn" Grid.Column="1"
                  Width="240"
                  Background="Transparent"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                  BorderThickness="0,0,1,0"
                  Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Chat 子导航：项目 / 会话 -->
                <Grid x:Name="ChatSubNavPanel" Grid.RowSpan="2" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="项目"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="20,24,16,16"
                               VerticalAlignment="Center"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid Margin="8,0,8,16">
                            <ListView ItemsSource="{x:Bind SidebarVM.Projects, Mode=OneWay}"
                                      SelectedItem="{x:Bind SidebarVM.SelectedProject, Mode=TwoWay}"
                                      SelectionMode="Single"
                                      HorizontalAlignment="Stretch"
                                      ItemContainerStyle="{StaticResource ProjectGroupItemStyle}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="nav:ProjectNavItemViewModel">
                                        <Expander IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                                  HorizontalAlignment="Stretch">
                                            <Expander.Header>
                                                <Grid Padding="12,10" HorizontalAlignment="Stretch">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Text="{x:Bind Name, Mode=OneWay}" />
                                                    <TextBlock Grid.Row="1"
                                                               Text="{x:Bind Subtitle, Mode=OneWay}"
                                                               FontSize="11"
                                                               Opacity="0.65"
                                                               Visibility="{x:Bind SubtitleVisibility, Mode=OneWay}"/>
                                                </Grid>
                                            </Expander.Header>

                                            <ListView ItemsSource="{x:Bind Sessions, Mode=OneWay}"
                                                      SelectedItem="{x:Bind SelectedSession, Mode=TwoWay}"
                                                      SelectionMode="Single"
                                                      HorizontalAlignment="Stretch"
                                                      ItemContainerStyle="{StaticResource SessionSubMenuItemStyle}">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate x:DataType="nav:SessionNavItemViewModel">
                                                        <TextBlock Text="{x:Bind Title, Mode=OneWay}" />
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Expander>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </ScrollViewer>
                </Grid>

                <!-- Settings 子导航 -->
                <Grid x:Name="SettingsSubNavPanel" Grid.RowSpan="2" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="设置"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="20,24,16,16"
                               VerticalAlignment="Center"/>

                    <ListView x:Name="SettingsSubMenuList"
                              Grid.Row="1"
                              SelectionMode="Single"
                              ItemContainerStyle="{StaticResource SubMenuItemStyle}"
                              SelectionChanged="OnSubMenuSelectionChanged">
                        <ListViewItem Content="常规" Tag="General" />
                        <ListViewItem Content="外观" Tag="Appearance" />
                        <ListViewItem Content="Agent (ACP)" Tag="AgentAcp" />
                        <ListViewItem Content="数据与存储" Tag="DataStorage" />
                        <ListViewItem Content="快捷键" Tag="Shortcuts" />
                        <ListViewItem Content="诊断与日志" Tag="Diagnostics" />
                        <ListViewItem Content="关于" Tag="About" />
                    </ListView>
                </Grid>

                <!-- Resizer: drag the right edge to resize the whole sub menu column -->
                <controls:ResizeGrip x:Name="SubMenuResizer"
                                     Grid.RowSpan="2"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Stretch"
                                     Width="6"
                                     Background="Transparent"
                                     Style="{StaticResource SubMenuResizerThumbStyle}"
                                     PointerPressed="OnSubMenuResizerPointerPressed"
                                     PointerMoved="OnSubMenuResizerPointerMoved"
                                     PointerReleased="OnSubMenuResizerPointerReleased"
                                     PointerCaptureLost="OnSubMenuResizerPointerCaptureLost" />
            </Grid>

            <!-- 第三列：主内容区 -->
            <Frame x:Name="ContentFrame"
                   Grid.Column="2"
                   Background="Transparent" />

            <!-- 右侧边栏：Diff / Todo / Files -->
            <Grid x:Name="RightPanelColumn"
                  Grid.Column="3"
                  Width="320"
                  Background="Transparent"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                  BorderThickness="1,0,0,0"
                  Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="RightPanelTitle"
                           Grid.Row="0"
                           Text=""
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="20,24,16,16" />

                <Grid Grid.Row="1">
                    <Grid x:Name="DiffPanel" Visibility="Collapsed">
                        <TextBlock Text="Diff 面板占位" Opacity="0.7" Margin="20,8" />
                    </Grid>
                    <Grid x:Name="TodoPanel" Visibility="Collapsed">
                        <TextBlock Text="Todo 面板占位" Opacity="0.7" Margin="20,8" />
                    </Grid>
                    <Grid x:Name="FilesPanel" Visibility="Collapsed">
                        <TextBlock Text="Files 面板占位" Opacity="0.7" Margin="20,8" />
                    </Grid>
                </Grid>

                <controls:ResizeGrip x:Name="RightPanelResizer"
                                     Grid.RowSpan="2"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Stretch"
                                     Width="6"
                                     Background="Transparent"
                                     Style="{StaticResource RightPanelResizerThumbStyle}"
                                     PointerPressed="OnRightPanelResizerPointerPressed"
                                     PointerMoved="OnRightPanelResizerPointerMoved"
                                     PointerReleased="OnRightPanelResizerPointerReleased"
                                     PointerCaptureLost="OnRightPanelResizerPointerCaptureLost" />
            </Grid>
        </Grid>
    </Grid>
</Page>
