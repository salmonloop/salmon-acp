<Application x:Class="SalmonEgg.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Microsoft.UI.Xaml.Controls">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <controls:XamlControlsResources />
                <ResourceDictionary Source="ms-appx:///Styles/ThemeFallback.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 
                 WinUI 3 (WindowsAppSDK) Bug Fix:
                 WinUI 3 fails to recursively find ThemeResource lookups if they are
                 defined inside ThemeDictionaries of a *merged* dictionary (ThemeFallback.xaml)
                 and looked up too early (e.g. in MainPage initialization).
                 By moving just the problematic keys directly to the root of App.xaml's
                 ResourceDictionary, we guarantee they are present at parse time on Windows.
            -->
            <!-- AppBackdropBrush must be Transparent to let the native Windows Mica/Acrylic material show through -->
            <SolidColorBrush x:Key="AppBackdropBrush" Color="Transparent" />
            
            <!-- Cards and Dividers missing in modern WinUI3 generic.xaml but used by our cross-platform views -->
            <!-- We route these legacy/custom names to actual modern WinUI3 theme resources -->
            <SolidColorBrush x:Key="LayerOnAcrylicFillColorDefaultBrush" Color="{ThemeResource LayerFillColorDefault}" />
            <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="{ThemeResource DividerStrokeColorDefault}" />
            
            <!-- Fallback text/accent for places where ThemeFallback was missed by WinUI3 -->
            <SolidColorBrush x:Key="SystemControlBackgroundBaseMediumLowBrush" Color="{ThemeResource LayerFillColorDefault}" />
            <SolidColorBrush x:Key="SystemControlForegroundOnAccentBrush" Color="{ThemeResource TextOnAccentFillColorPrimary}" />

            <!-- Settings layout (Win11-like): fixed content column on wide windows, fluid on narrow ones -->
            <x:Double x:Key="SettingsContentMaxWidth">780</x:Double>

            <!-- Win11-like breadcrumb (merged with title) -->
            <Style x:Key="SettingsBreadcrumbLinkStyle" TargetType="HyperlinkButton">
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="FontSize" Value="30" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <!-- Standard BreadcrumbBar item text (used by SettingsBreadcrumbBar control). -->
            <Style x:Key="SettingsBreadcrumbBarTextStyle" TargetType="TextBlock">
                <Setter Property="Margin" Value="0" />
                <Setter Property="FontSize" Value="30" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="SettingsBreadcrumbCurrentTextStyle" TargetType="TextBlock">
                <Setter Property="Margin" Value="0" />
                <Setter Property="FontSize" Value="30" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="SettingsBreadcrumbSeparatorTextStyle" TargetType="TextBlock">
                <Setter Property="Margin" Value="0" />
                <Setter Property="FontSize" Value="30" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Opacity" Value="0.55" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <!-- 定义 SubtleButtonStyle 兼容样式 -->
            <!-- 解决 "Couldn't statically resolve resource SubtleButtonStyle" 警告 -->
            <Style x:Key="SubtleButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="8,4" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter x:Name="SubtleStyleContentPresenter"
                                              Background="{TemplateBinding Background}"
                                              BorderBrush="{TemplateBinding BorderBrush}"
                                              BorderThickness="{TemplateBinding BorderThickness}"
                                              Content="{TemplateBinding Content}"
                                              ContentTransitions="{TemplateBinding ContentTransitions}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Title bar buttons: keep UI consistent across pages + provide proper pointer/pressed feedback. -->
            <Style x:Key="TitleBarCommandButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="36" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="8" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}" />
                                                <Setter Target="Root.BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}" />
                                                <Setter Target="Root.BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Opacity" Value="0.45" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <!-- Scale icon-only content with the button size (title bar is DPI/height sensitive). -->
                                <Viewbox x:Name="ContentScaleBox"
                                         Margin="{TemplateBinding Padding}"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         Stretch="Uniform">
                                    <ContentPresenter x:Name="Presenter"
                                                      Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      HorizontalContentAlignment="Center"
                                                      VerticalContentAlignment="Center" />
                                </Viewbox>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="TitleBarToggleButtonStyle" TargetType="ToggleButton">
                <Setter Property="Width" Value="36" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Padding" Value="8" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}" />
                                                <Setter Target="Root.BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}" />
                                                <Setter Target="Root.BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Opacity" Value="0.45" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                    <VisualStateGroup x:Name="CheckStates">
                                        <VisualState x:Name="Unchecked" />
                                        <VisualState x:Name="Checked">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}" />
                                                <Setter Target="Root.BorderBrush" Value="{ThemeResource AccentBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <!-- Scale icon-only content with the button size (title bar is DPI/height sensitive). -->
                                <Viewbox x:Name="ContentScaleBox"
                                         Margin="{TemplateBinding Padding}"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         Stretch="Uniform">
                                    <ContentPresenter x:Name="Presenter"
                                                      Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      HorizontalContentAlignment="Center"
                                                      VerticalContentAlignment="Center" />
                                </Viewbox>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- App backdrop fallback now defined in ThemeDictionaries above. -->

        </ResourceDictionary>
    </Application.Resources>

</Application>
