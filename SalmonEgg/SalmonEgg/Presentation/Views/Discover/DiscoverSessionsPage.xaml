<Page
    x:Class="SalmonEgg.Presentation.Views.Discover.DiscoverSessionsPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SalmonEgg.Presentation.Views.Discover"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:SalmonEgg.Presentation.ViewModels.Discover"
    xmlns:models="using:SalmonEgg.Domain.Models"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left Pane: Profiles -->
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="1" />
            <!-- Right Pane: Sessions -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Pane: Profiles Master List -->
        <Grid Grid.Column="0" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="24,32,24,16" Spacing="8">
                <TextBlock
                    Text="发现会话"
                    Style="{ThemeResource TitleLargeTextBlockStyle}"
                    FontWeight="SemiBold" />
                <TextBlock
                    Text="选择一个节点来浏览会话"
                    Style="{ThemeResource BodyTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <ListView
                Grid.Row="1"
                ItemsSource="{x:Bind ViewModel.AvailableProfiles, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedProfile, Mode=TwoWay}"
                SelectionMode="Single"
                IsItemClickEnabled="True">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:ServerConfiguration">
                        <StackPanel Padding="12,8">
                            <TextBlock Text="{x:Bind Name}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="{x:Bind TransportDisplayName}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Divider -->
        <Rectangle Grid.Column="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Right Pane: Sessions Details -->
        <Grid Grid.Column="2" Background="Transparent">
            <!-- Empty State when no profile is selected -->
            <Grid Visibility="{x:Bind ViewModel.SelectedProfile, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE716;" FontSize="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock Text="请在左侧选择一个 Agent 节点" Style="{ThemeResource SubtitleTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>

            <!-- Sessions Content Area -->
            <Grid Visibility="{x:Bind ViewModel.SelectedProfile, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" MaxWidth="800" HorizontalAlignment="Left" Margin="48,32,48,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header for Selected Profile -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.SelectedProfile.Name, Mode=OneWay}" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="SemiBold" />
                        <TextBlock Text="可导入的会话列表" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <Button
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Command="{x:Bind ViewModel.RefreshSessionsCommand}"
                        IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}"
                        Style="{StaticResource DefaultButtonStyle}"
                        ToolTipService.ToolTip="刷新会话列表">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE72C;" FontSize="14" />
                            <TextBlock Text="刷新" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Loading & Error States Overlay -->
                <Grid Grid.Row="1" Canvas.ZIndex="10">
                    <Grid
                        Background="Transparent"
                        Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <StackPanel Spacing="16">
                            <ProgressRing IsActive="True" Width="48" Height="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="正在连接并扫描会话列表..." Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <InfoBar
                        Title="无法加载会话"
                        Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                        Severity="Error"
                        IsOpen="True"
                        IsClosable="False"
                        VerticalAlignment="Top"
                        Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                </Grid>

                <!-- Sessions List (Only visible when not loading and no errors) -->
                <ListView
                    Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.AgentSessions, Mode=OneWay}"
                    SelectionMode="None"
                    IsItemClickEnabled="False">

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="0,0,0,12"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:DiscoverSessionItemViewModel">
                            <Border
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16">

                                <!-- Simple hover effect -->
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="ActionBtn.Opacity" Value="1.0"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon -->
                                    <Border Grid.Column="0"
                                            Width="40" Height="40"
                                            CornerRadius="6"
                                            Background="{ThemeResource SystemControlBackgroundAccentBrush}"
                                            Margin="0,0,16,0"
                                            VerticalAlignment="Top">
                                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                  Glyph="&#xE8F2;"
                                                  Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                  FontSize="18" />
                                    </Border>

                                    <!-- Details -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock
                                            Text="{x:Bind Title}"
                                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                                            TextWrapping="NoWrap"
                                            TextTrimming="CharacterEllipsis" />

                                        <TextBlock
                                            Text="{x:Bind Description}"
                                            Style="{ThemeResource BodyTextBlockStyle}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Margin="0,4,0,0"
                                            TextWrapping="Wrap"
                                            MaxLines="2"
                                            TextTrimming="CharacterEllipsis" />

                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE787;" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                            <TextBlock
                                                Text="{x:Bind FormattedDate}"
                                                Style="{ThemeResource CaptionTextBlockStyle}"
                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Action -->
                                    <Button
                                        x:Name="ActionBtn"
                                        Grid.Column="2"
                                        Content="导入会话"
                                        Style="{StaticResource AccentButtonStyle}"
                                        VerticalAlignment="Center"
                                        Command="{Binding ViewModel.LoadSessionCommand, ElementName=RootPage}"
                                        CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Page>