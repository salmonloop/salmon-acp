<Page x:Class="SalmonEgg.Presentation.Views.MiniWindow.MiniChatView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:SalmonEgg.Presentation.ViewModels.Chat"
      xmlns:converters="using:SalmonEgg.Presentation.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="Transparent"
      AllowDrop="False">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:MessageDirectionToAlignmentConverter x:Key="HorizontalAlignmentConverter" />
        <converters:TimeFormatConverter x:Key="TimeFormatConverter" />

        <DataTemplate x:Key="MessageTemplate" x:DataType="vm:ChatMessageViewModel">
            <Grid Margin="0,8"
                  HorizontalAlignment="{x:Bind IsOutgoing, Converter={StaticResource HorizontalAlignmentConverter}, Mode=OneWay}">
                <Border CornerRadius="12"
                        Padding="12,8"
                        Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Visibility="{x:Bind HasTitle, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Margin="0,0,0,4" />

                        <StackPanel Visibility="{x:Bind IsThinkingPlaceholder, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    Margin="0,4">
                            <ProgressRing IsActive="True"
                                          Width="16"
                                          Height="16"
                                          VerticalAlignment="Center" />
                            <TextBlock Text="思考中..."
                                       Opacity="0.6"
                                       VerticalAlignment="Center"
                                       FontSize="12" />
                        </StackPanel>

                        <TextBlock Text="{x:Bind TextContent, Mode=OneWay}"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   Visibility="{x:Bind HasTextContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <TextBlock Text="{x:Bind Timestamp, Mode=OneWay, Converter={StaticResource TimeFormatConverter}}"
                                   FontSize="11"
                                   Opacity="0.6"
                                   HorizontalAlignment="Right"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid x:Name="RootGrid"
          RowDefinitions="Auto,*,Auto,Auto"
          Background="Transparent">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="WindowWidthStates">
                <VisualState x:Name="Narrow">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MiniTitleBar.Padding" Value="12,0" />
                        <Setter Target="MessagesList.Padding" Value="12" />
                        <Setter Target="InputBorder.Padding" Value="12,10" />
                        <Setter Target="SendPanel.Padding" Value="12,0,12,12" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="520" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MiniTitleBar.Padding" Value="16,0" />
                        <Setter Target="MessagesList.Padding" Value="16" />
                        <Setter Target="InputBorder.Padding" Value="16,10" />
                        <Setter Target="SendPanel.Padding" Value="16,0,16,16" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!-- "Title bar" content (in-content; avoids platform-specific titlebar APIs) -->
        <Border x:Name="MiniTitleBar"
                Grid.Row="0"
                Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Height="48"
                Padding="12,0">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <ComboBox Grid.Column="0"
                          MinWidth="0"
                          ItemsSource="{x:Bind ViewModel.MiniWindowSessions, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedMiniWindowSession, Mode=TwoWay}"
                          PlaceholderText="选择会话"
                          VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:MiniWindowConversationItemViewModel">
                            <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Button Grid.Column="1"
                        Style="{StaticResource TitleBarCommandButtonStyle}"
                        ToolTipService.ToolTip="返回主窗口"
                        AutomationProperties.Name="ReturnToWindow"
                        VerticalAlignment="Center"
                        Command="{x:Bind ViewModel.ReturnToMainWindowCommand}">
                    <!-- "BackToWindow" glyph (Segoe Fluent Icons / MDL2-compatible on WinUI) -->
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE73F;" />
                </Button>
            </Grid>
        </Border>

        <!-- Messages -->
        <ListView x:Name="MessagesList"
                  Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.MessageHistory, Mode=OneWay}"
                  ItemTemplate="{StaticResource MessageTemplate}"
                  Padding="12"
                  SelectionMode="None"
                  HorizontalAlignment="Stretch"
                  MinWidth="0"
                  Loaded="OnMessagesListLoaded" />

        <!-- Input -->
        <Border x:Name="InputBorder"
                Grid.Row="2"
                Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,10">
            <TextBox Text="{x:Bind ViewModel.CurrentPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="输入消息"
                     MinHeight="44"
                     AcceptsReturn="True"
                     TextWrapping="Wrap" />
        </Border>

        <!-- Send -->
        <Grid x:Name="SendPanel"
              Grid.Row="3"
              Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
              Padding="12,0,12,12">
            <Button Content="发送"
                    HorizontalAlignment="Right"
                    Padding="16,6"
                    Command="{x:Bind ViewModel.SendPromptCommand}"
                    IsEnabled="{x:Bind ViewModel.CanSendPromptUi, Mode=OneWay}" />
        </Grid>
    </Grid>
</Page>
