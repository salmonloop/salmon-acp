<UserControl
    x:Class="SalmonEgg.Controls.ToolCallPill"
    x:Name="RootControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    xmlns:models="using:SalmonEgg.Presentation.Models"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <DataTemplate x:Key="ToolCallTextContentTemplate" x:DataType="controls:ToolCallDisplayItem">
            <TextBlock
                Text="{x:Bind Text, Mode=OneWay}"
                Style="{StaticResource BodyTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                TextWrapping="Wrap"
                IsTextSelectionEnabled="True" />
        </DataTemplate>

        <DataTemplate x:Key="ToolCallDiffContentTemplate" x:DataType="controls:ToolCallDisplayItem">
            <Grid RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Text="{x:Bind Path, Mode=OneWay}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextTrimming="CharacterEllipsis"
                    Visibility="{x:Bind HasPath, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                <TextBlock
                    Grid.Row="1"
                    Text="{x:Bind OldText, Mode=OneWay}"
                    FontFamily="Consolas, 'Courier New', Monospace"
                    FontSize="12"
                    TextWrapping="Wrap"
                    IsTextSelectionEnabled="True"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    Visibility="{x:Bind HasOldText, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                <TextBlock
                    Grid.Row="2"
                    Text="{x:Bind NewText, Mode=OneWay}"
                    FontFamily="Consolas, 'Courier New', Monospace"
                    FontSize="12"
                    TextWrapping="Wrap"
                    IsTextSelectionEnabled="True"
                    Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                    Visibility="{x:Bind HasNewText, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ToolCallTerminalContentTemplate" x:DataType="controls:ToolCallDisplayItem">
            <Border
                Background="{ThemeResource ControlFillColorTertiaryBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12">
                <StackPanel Spacing="4">
                    <TextBlock
                        Text="{x:Bind TerminalId, Mode=OneWay}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Visibility="{x:Bind HasTerminalId, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock
                        Text="{x:Bind Text, Mode=OneWay}"
                        FontFamily="Consolas, 'Courier New', Monospace"
                        FontSize="12"
                        TextWrapping="Wrap"
                        IsTextSelectionEnabled="True"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <controls:ToolCallContentTemplateSelector
            x:Key="ToolCallContentTemplateSelector"
            TextTemplate="{StaticResource ToolCallTextContentTemplate}"
            DiffTemplate="{StaticResource ToolCallDiffContentTemplate}"
            TerminalTemplate="{StaticResource ToolCallTerminalContentTemplate}" />
    </UserControl.Resources>

    <Border
        x:Name="RootFrame"
        Background="Transparent"
        Padding="0"
        HorizontalAlignment="Left"
        AutomationProperties.Name="{x:Bind AutomationName, Mode=OneWay}">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="AdaptiveStates">
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootFrame.HorizontalAlignment" Value="Stretch" />
                        <Setter Target="RootFrame.MaxWidth" Value="10000" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="MediumState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="640" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootFrame.HorizontalAlignment" Value="Left" />
                        <Setter Target="RootFrame.MaxWidth" Value="500" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1008" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootFrame.HorizontalAlignment" Value="Left" />
                        <Setter Target="RootFrame.MaxWidth" Value="640" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>

            <VisualStateGroup x:Name="LifecycleStates">
                <VisualState x:Name="CompletedState">
                    <VisualState.StateTriggers>
                        <StateTrigger IsActive="{x:Bind IsCompleted, Mode=OneWay}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootFrame.Opacity" Value="0.65" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="CancelledState">
                    <VisualState.StateTriggers>
                        <StateTrigger IsActive="{x:Bind IsCancelled, Mode=OneWay}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootFrame.Opacity" Value="0.5" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
            <VisualStateGroup x:Name="DetailStates">
                <VisualStateGroup.Transitions>
                    <VisualTransition From="DetailCollapsedState" To="DetailExpandedState">
                        <Storyboard>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="DetailScrollViewer" Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible" />
                            </ObjectAnimationUsingKeyFrames>
                            <DoubleAnimation
                                Storyboard.TargetName="DetailScrollViewer"
                                Storyboard.TargetProperty="Opacity"
                                From="0.0" To="1.0"
                                Duration="0:0:0.25">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation
                                Storyboard.TargetName="DetailTransform"
                                Storyboard.TargetProperty="Y"
                                From="-8" To="0"
                                Duration="0:0:0.25">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </VisualTransition>
                    <VisualTransition From="DetailExpandedState" To="DetailCollapsedState">
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="DetailScrollViewer"
                                Storyboard.TargetProperty="Opacity"
                                From="1.0" To="0.0"
                                Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseIn" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation
                                Storyboard.TargetName="DetailTransform"
                                Storyboard.TargetProperty="Y"
                                From="0" To="-8"
                                Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseIn" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="DetailScrollViewer" Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="Collapsed" />
                            </ObjectAnimationUsingKeyFrames>
                        </Storyboard>
                    </VisualTransition>
                </VisualStateGroup.Transitions>

                <VisualState x:Name="DetailCollapsedState">
                    <VisualState.Setters>
                        <Setter Target="DetailScrollViewer.Visibility" Value="Collapsed" />
                        <Setter Target="DetailScrollViewer.Opacity" Value="0" />
                        <Setter Target="DetailTransform.Y" Value="-8" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="DetailExpandedState">
                    <VisualState.Setters>
                        <Setter Target="DetailScrollViewer.Visibility" Value="Visible" />
                        <Setter Target="DetailScrollViewer.Opacity" Value="1" />
                        <Setter Target="DetailTransform.Y" Value="0" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid Padding="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid
                x:Name="HeaderGrid"
                Grid.Row="0"
                Background="Transparent"
                Tapped="HeaderGrid_Tapped"
                PointerEntered="HeaderGrid_PointerEntered"
                PointerExited="HeaderGrid_PointerExited"
                KeyUp="HeaderGrid_KeyUp"
                IsTabStop="True"
                UseSystemFocusVisuals="True">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid
                        Grid.Column="0"
                        Width="20"
                        Height="20"
                        VerticalAlignment="Top"
                        ChildrenTransitions="{x:Bind models:UiMotion.Current.StatusIconTransitions, Mode=OneWay}">
                        <ProgressRing
                            IsActive="{x:Bind IsInProgress, Mode=OneWay}"
                            Width="14"
                            Height="14"
                            Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                            Visibility="{x:Bind IsInProgress, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <FontIcon
                            Glyph="&#xE10B;"
                            FontSize="12"
                            Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                            Visibility="{x:Bind IsCompleted, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <FontIcon
                            Glyph="&#xE10A;"
                            FontSize="12"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                            Visibility="{x:Bind IsFailed, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <FontIcon
                            Glyph="&#xE711;"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Visibility="{x:Bind IsCancelled, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>

                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock
                            x:Name="ToolNameTextBlock"
                            Text="{x:Bind DisplayToolName, Mode=OneWay}"
                            Style="{StaticResource BodyTextBlockStyle}"
                            FontWeight="Normal"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Text="{x:Bind DisplaySummary, Mode=OneWay}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextTrimming="CharacterEllipsis"
                            MaxLines="1" />
                    </StackPanel>
                </Grid>
            </Grid>

            <ScrollViewer
                x:Name="DetailScrollViewer"
                Grid.Row="1"
                Margin="28,8,0,0"
                MaxHeight="{x:Bind PreviewMaxHeight, Mode=OneWay}"
                VerticalScrollBarVisibility="Hidden"
                HorizontalScrollBarVisibility="Disabled"
                Visibility="Collapsed"
                Opacity="0">
                <ScrollViewer.RenderTransform>
                    <TranslateTransform x:Name="DetailTransform" Y="-8" />
                </ScrollViewer.RenderTransform>
                <StackPanel Spacing="8">
                    <TextBlock
                        Text="{x:Bind PayloadHeaderText, Mode=OneWay}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Visibility="{x:Bind HasDisplayItems, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind HasPendingPermissionRequest, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock
                            Text="{x:Bind PermissionHeaderText, Mode=OneWay}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                                Content="{x:Bind AllowPermissionOption.Name, Mode=OneWay, FallbackValue=Allow}"
                                Tag="{x:Bind AllowPermissionOption, Mode=OneWay}"
                                Click="OnPermissionOptionClick"
                                Style="{StaticResource AccentButtonStyle}"
                                Visibility="{x:Bind HasAllowPermissionOption, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <Button
                                Content="{x:Bind RejectPermissionOption.Name, Mode=OneWay, FallbackValue=Reject}"
                                Tag="{x:Bind RejectPermissionOption, Mode=OneWay}"
                                Click="OnPermissionOptionClick"
                                Style="{StaticResource DefaultButtonStyle}"
                                Visibility="{x:Bind HasRejectPermissionOption, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                    </StackPanel>

                    <ItemsControl
                        ItemsSource="{x:Bind DisplayItems, Mode=OneWay}"
                        ItemTemplateSelector="{StaticResource ToolCallContentTemplateSelector}"
                        Visibility="{x:Bind HasDisplayItems, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <ItemsControl
                        ItemsSource="{x:Bind LocationItems, Mode=OneWay}"
                        Visibility="{x:Bind HasLocationItems, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="controls:ToolCallLocationDisplayItem">
                                <HyperlinkButton
                                    Content="{x:Bind DisplayText, Mode=OneWay}"
                                    Padding="0"
                                    FontSize="12"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
