<UserControl
    x:Class="SalmonEgg.Controls.ResponsiveFormRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="using:SalmonEgg.Presentation.Utilities"
    mc:Ignorable="d">

    <Grid x:Name="LayoutRoot"
          Style="{StaticResource SettingsRowGridStyle}">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="WidthStates">
                <VisualState x:Name="Narrow">
                    <VisualState.Setters>
                        <Setter Target="LayoutRoot.ColumnSpacing" Value="0" />
                        <Setter Target="LayoutRoot.RowSpacing" Value="6" />
                        <Setter Target="LabelColumn.Width" Value="*" />
                        <Setter Target="ValueColumn.Width" Value="*" />
                        <Setter Target="ValuePresenter.(Grid.Row)" Value="1" />
                        <Setter Target="ValuePresenter.(Grid.Column)" Value="0" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers>
                        <utils:MinActualWidthTrigger TargetElement="{x:Bind LayoutRoot}" MinWidth="560" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="LayoutRoot.ColumnSpacing" Value="16" />
                        <Setter Target="LayoutRoot.RowSpacing" Value="4" />
                        <Setter Target="LabelColumn.Width" Value="220" />
                        <Setter Target="ValueColumn.Width" Value="*" />
                        <Setter Target="ValuePresenter.(Grid.Row)" Value="0" />
                        <Setter Target="ValuePresenter.(Grid.Column)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LabelColumn" Width="*" />
            <ColumnDefinition x:Name="ValueColumn" Width="*" />
        </Grid.ColumnDefinitions>

        <ContentPresenter Content="{x:Bind Label, Mode=OneWay}"
                          VerticalAlignment="Center" />
        <ContentPresenter x:Name="ValuePresenter"
                          Grid.Column="1"
                          Content="{x:Bind Value, Mode=OneWay}"
                          VerticalAlignment="Center" />
    </Grid>
</UserControl>
